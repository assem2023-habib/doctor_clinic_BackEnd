							"body": "{\n    \"access_token\": \"eyJ0eXAiOiJKV1Qi...\",\n    \"refresh_token\": \"def50200...\",\n    \"expires_in\": 31536000,\n    \"token_type\": \"Bearer\",\n    \"user\": {\n        \"id\": \"019e1d0f-...\",\n        \"first_name\": \"Layla\",\n        \"last_name\": \"Hassan\",\n        \"email\": \"receptionist@example.com\",\n        \"role\": \"receptionist\",\n        \"shift_start\": \"09:00\",\n        \"shift_end\": \"17:00\",\n        \"phone\": \"+963912345680\",\n        \"gender\": \"female\",\n        \"birthday_date\": \"1998-11-05\",\n        \"is_active\": true\n    }\n}"
