							"name": "Success (Patient)",
							"status": "OK",
							"code": 200,
							"body": "{\n    \"id\": \"019e1d0f-...\",\n    \"first_name\": \"Ahmed\",\n    \"last_name\": \"Ali\",\n    \"email\": \"patient@example.com\",\n    \"role\": \"patient\",\n    \"phone\": \"+963912345678\",\n    \"address\": \"Damascus, Syria\",\n    \"gender\": \"male\",\n    \"birthday_date\": \"1995-06-15\",\n    \"is_active\": true\n}"
