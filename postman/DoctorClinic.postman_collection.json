							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"first_name\": \"Khaled\",\n    \"last_name\": \"Suleiman\",\n    \"username\": \"drkhaled\",\n    \"email\": \"doctor@example.com\",\n    \"phone\": \"+963912345679\",\n    \"address\": \"Aleppo, Syria\",\n    \"gender\": \"male\",\n    \"birthday_date\": \"1985-03-20\",\n    \"password\": \"Password@123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/register/doctor",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth", "register", "doctor"]
						}
					},
					"response": [
						{
							"name": "Created",
							"status": "Created",
							"code": 201,
							"body": "{\n    \"access_token\": \"eyJ0eXAiOiJKV1Qi...\",\n    \"refresh_token\": \"def50200...\",\n    \"expires_in\": 31536000,\n    \"token_type\": \"Bearer\",\n    \"user\": {\n        \"id\": \"019e1d0f-...\",\n        \"first_name\": \"Khaled\",\n        \"last_name\": \"Suleiman\",\n        \"email\": \"doctor@example.com\",\n        \"role\": \"doctor\",\n        \"phone\": \"+963912345679\",\n        \"gender\": \"male\",\n        \"birthday_date\": \"1985-03-20\",\n        \"is_active\": true\n    }\n}"
						}
					]
				},
