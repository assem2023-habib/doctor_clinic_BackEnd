			],
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Auto-attach Bearer token to all Auth folder requests",
							"var token = pm.collectionVariables.get('access_token');",
							"if (token) {",
							"    pm.request.headers.add({",
							"        key: 'Authorization',",
							"        value: 'Bearer ' + token",
							"    });",
							"}"
						],
						"type": "text/javascript"
					}
				}
			]
		}
	]
}
